---
extends: default

ignore: |
  *.tpl
  .cache
  *venv/
  LEGACY/**
  collections/ansible_collections/**
  roles*/**

rules:
  comments-indentation: disable
  comments:
    min-spaces-from-content: 1
  braces:
    max-spaces-inside: 1
  line-length:
    max: 120
    allow-non-breakable-inline-mappings: true
    ignore: |
      playbooks/*.yml
  octal-values:
    forbid-implicit-octal: true
    forbid-explicit-octal: true
  truthy:
    ignore: |
      playbooks/*.yml
